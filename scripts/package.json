{
  "name": "mushin-scripts",
  "type": "module",
  "version": "0.1.0",
  "description": "Manage the monorepo",
  "author": "Setobox <setoboxes@gmail.com>",
  "license": "MIT",
  "keywords": [
    "monorepo",
    "build",
    "mushin",
    "scripts"
  ],
  "exports": "./dist/index.js",
  "module": "dist/index.js",
  "bin": "dist/cli.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build-fast": "pnpm build --no-dts",
    "build-dts": "tsc -d --emitDeclarationOnly",
    "dev": "pnpm build-fast --watch",
    "mushin": "node dist/bin.js",
    "prepublishOnly": "pnpm build",
    "test": "pnpm build && pnpm test-only",
    "test-only": "vitest run",
    "test-build": "node dist/bin.js build './test/fixture/'"
  },
  "peerDependencies": {
    "typescript": "*"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "chalk": "^5.2.0",
    "esbuild": "^0.17.8",
    "esbuild-register": "^3.4.2",
    "fast-glob": "^3.2.12",
    "globby": "^13.1.3",
    "js-yaml": "^4.1.0",
    "load-tsconfig": "^0.2.3",
    "rollup": "^3.17.3",
    "rollup-plugin-dts": "^5.2.0",
    "which-pm-runs": "^1.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.5",
    "@types/which-pm-runs": "^1.0.0",
    "tsup": "^6.6.3",
    "typescript": "^4.9.5",
    "vitest": "^0.28.5"
  }
}
