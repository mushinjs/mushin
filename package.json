{
  "name": "mushin-repo",
  "private": true,
  "license": "AGPL-3.0",
  "author": "Setobox <setoboxes@gmail.com>",
  "scripts": {
    "build": "pnpm -r --no-bail build",
    "dev": "pnpm -r --no-bail dev",
    "clean": "pnpm rimraf pnpm-lock.yaml node_modules {packages,plugins,scripts}/**/{dist,tsconfig.tsbuildinfo,temp,node_modules}",
    "lint": "eslint . --fix --cache",
    "prepublish": "pnpm build",
    "publish": "pnpm -r publish",
    "start": "pnpm --filter mushin start",
    "test": "vitest"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^0.35.2",
    "@types/node": "^18.13.0",
    "@typescript-eslint/eslint-plugin": "^5.52.0",
    "@typescript-eslint/parser": "^5.52.0",
    "c8": "^7.12.0",
    "esbuild": "^0.17.8",
    "esbuild-register": "^3.4.2",
    "eslint": "^8.34.0",
    "eslint-config-standard": "^17.0.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-n": "^15.6.1",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^6.1.1",
    "glob-watcher": "^5.0.5",
    "globby": "^13.1.3",
    "picocolors": "^1.0.0",
    "rimraf": "^4.1.2",
    "ts-node": "^10.9.1",
    "tsup": "^6.6.3",
    "typescript": "^4.9.5",
    "vitest": "^0.28.5"
  },
  "engines": {
    "node": ">=16",
    "pnpm": ">=7"
  }
}
